# Supabase Postgres — use the Transaction Pooler URL (port 6543), NOT the direct connection.
# Project Settings → Database → Connection string → "Transaction pooler" tab.
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-X-<REGION>.pooler.supabase.com:6543/postgres

# Supabase project URL + anon (publishable) key. Found at Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# OpenAI — used for both chat (gpt-5.5) and embeddings (text-embedding-3-small).
OPENAI_API_KEY=sk-proj-...

# Optional: AssemblyAI for transcribing audio/video training material.
# Only needed if you'll run `bun run transcribe`. Free tier = 5 hours/month.
# Sign up at https://www.assemblyai.com
# ASSEMBLYAI_API_KEY=

# Optional: blog ingest via the in-app endpoint (/api/ingest-blog), which reuses
# this deployment's DATABASE_URL + OPENAI_API_KEY — no need to copy secrets to CI.
# INGEST_TOKEN — a value YOU choose; call ?token=<it> to trigger a run manually.
# INGEST_TOKEN=
# CRON_SECRET  — a value YOU choose; enables the weekly Vercel Cron in vercel.json
#   (Vercel auto-sends it as a Bearer token on scheduled runs).
# CRON_SECRET=
