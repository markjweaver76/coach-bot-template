# Supabase Postgres — use the Transaction Pooler URL (port 6543), NOT the direct connection.
# Project Settings → Database → Connection string → "Transaction pooler" tab.
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-X-<REGION>.pooler.supabase.com:6543/postgres

# Supabase project URL + anon (publishable) key. Found at Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# OpenAI — used for both chat (gpt-5.5) and embeddings (text-embedding-3-small).
OPENAI_API_KEY=sk-proj-...
